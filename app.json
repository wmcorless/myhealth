{
  "expo": {
    "name": "MyHealth",
    "slug": "myhealth",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "scheme": "myhealth",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.wmcorless.myhealth",
      "infoPlist": {
        "NSHealthShareUsageDescription": "MyHealth reads your health and fitness data to display it in one place.",
        "NSHealthUpdateUsageDescription": "MyHealth may write workout summaries to Apple Health."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.wmcorless.myhealth",
      "permissions": [
        "android.permission.ACTIVITY_RECOGNITION",
        "android.permission.BODY_SENSORS",
        "android.permission.health.READ_HEART_RATE",
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_DISTANCE",
        "android.permission.health.READ_EXERCISE",
        "android.permission.health.READ_ACTIVE_CALORIES_BURNED",
        "android.permission.health.READ_RESTING_HEART_RATE",
        "android.permission.health.READ_BLOOD_GLUCOSE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-web-browser",
      "expo-secure-store",
      "expo-dev-client",
      [
        "react-native-health-connect",
        {
          "permissions": [
            "HeartRate",
            "Steps",
            "Distance",
            "ExerciseSession",
            "ActiveCaloriesBurned",
            "RestingHeartRate",
            "BloodGlucose"
          ]
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.1.21",
            "minSdkVersion": 26,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          }
        }
      ],
      "expo-sqlite"
    ],
    "extra": {
      "eas": {
        "projectId": "febdd274-af77-4813-b54d-9157f8d261b9"
      }
    },
    "owner": "wmcorless"
  }
}
